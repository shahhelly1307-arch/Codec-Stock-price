import layers, models\n","import matplotlib.pyplot as plt\n","import numpy as np\n","\n","# For Jupyter Notebooks to display charts automatically\n","%matplotlib inline\n","\n","print(\"Step 1: Loading and preprocessing the MNIST dataset...\")\n","# Load the built-in MNIST dataset\n","mnist = tf.keras.datasets.mnist\n","(X_train, y_train), (X_test, y_test) = mnist.load_data()\n","\n","# Normalize pixel values to be between 0.0 and 1.0\n","X_train, X_test = X_train / 255.0, X_test / 255.0\n","\n","# Reshape data to add the single channel (grayscale) dimension\n","# Shape changes from (60000, 28, 28) to (60000, 28, 28, 1)\n","X_train = np.expand_dims(X_train, axis=-1)\n","X_test = np.expand_dims(X_test, axis=-1)\n","\n","print(f\"Training data shape: {X_train.shape}\")\n","print(f\"Testing data shape: {X_test.shape}\")\n","\n","print(\"\\nStep 2: Building the Convolutional Neural Network (CNN)...\")\n","model = models.Sequential([\n","    # First Convolutional Layer: Detects 32 basic features (edges/lines)\n","    layers.Conv2D(32, (3, 3), activation='relu', input_shape=(28, 28, 1)),\n","    layers.MaxPooling2D((2, 2)),\n","\n","    # Second Convolutional Layer: Detects 64 more complex shapes\n","    layers.Conv2D(64, (3, 3), activation='relu'),\n","    layers.MaxPooling2D((2, 2)),\n","\n","    # Flatten the 2D feature maps into a 1D vector\n","    layers.Flatten(),\n","\n","    # Dense Layer: Core reasoning layer with 64 neurons\n","    layers.Dense(64, activation='relu'),\n","\n","    # Output Layer: 10 neurons corresponding to classes 0-9 (using Softmax for probabilities)\n","    layers.Dense(10, activation='softmax')\n","])\n","\n","# Display the structural summary of your network\n","model.summary()\n","\n","print(\"\\nStep 3: Compiling the model...\")\n","model.compile(optimizer='adam',\n","              loss='sparse_categorical_crossentropy',\n","              metrics=['accuracy'])\n","\n","print(\"\\nStep 4: Training the CNN (Running 5 Epochs)...\")\n","# An epoch is one full pass through all 60,000 training images\n","history = model.fit(X_train, y_train, epochs=5, validation_data=(X_test, y_test))\n","\n","print(\"\\n================ EVALUATION METRICS ================\")\n","test_loss, test_acc = model.evaluate(X_test, y_test, verbose=0)\n","print(f\"Final Test Accuracy: {test_acc * 100:.2f}%\")\n","print(f\"Final Test Loss: {test_loss:.4f}\")\n","print(\"====================================================\")\n","\n","print(\"\\nStep 5: Visualizing Training Progress...\")\n","plt.figure(figsize=(12, 4))\n","plt.subplot(1, 2, 1)\n","plt.plot(history.history['accuracy'], label='Train Accuracy')\n","plt.plot(history.history['val_accuracy'], label='Test Accuracy')\n","plt.title('Accuracy over Epochs')\n","plt.legend()\n","\n","plt.subplot(1, 2, 2)\n","plt.plot(history.history['loss'], label='Train Loss')\n","plt.plot(history.history['val_loss'], label='Test Loss')\n","plt.title('Loss over Epochs')\n","plt.legend()\n","plt.show()\n","\n","print(\"\\n🔮 Step 6: Testing Live Custom Image Predictions...\")\n","# Let's pull 3 random images from our test dataset to see what the AI thinks\n","random_indices = np.random.choice(len(X_test), 3, replace=False)\n","\n","for idx in random_indices:\n","    test_image = X_test[idx]\n","    actual_label = y_test[idx]\n","\n","    # Reshape image back to 2D for plotting, but keep 4D array for model input\n","    input_tensor = np.expand_dims(test_image, axis=0)\n","    prediction_probs = model.predict(input_tensor, verbose=0)\n","    predicted_label = np.argmax(prediction_probs)\n","\n","    # Show the image\n","    plt.figure(figsize=(2,2))\n","    plt.imshow(test_image.squeeze(), cmap='gray')\n","    plt.title(f\"Actual: {actual_label} | Predicted: {predicted_label}\")\n","    plt.axis('off')\n","    plt.show()"]}]}